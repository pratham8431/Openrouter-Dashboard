# Required for the AI Recommender module
# Get your key at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_key_here

# Required for the cron email alert agent (cron/watch-alert.js)
# Use a Gmail app password — https://myaccount.google.com/apppasswords
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Required for auto-switch fallback recommendations in the cron agent
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required for the public-repo scanner (scanner/scan.js)
# GitHub's code search API requires auth — no special scopes needed.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
